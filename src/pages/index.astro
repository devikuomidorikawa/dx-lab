---
import { getCollection } from "astro:content"
import Base from "../layouts/Base.astro"
import TagList from "../components/TagList.astro"

const allProjects = await getCollection("projects")
const projects = allProjects.filter((p) => p.data.status !== "draft")
const sorted = [...projects].sort((a, b) => b.data.createdAt.localeCompare(a.data.createdAt))

const tagCounts = new Map<string, number>()
projects.forEach((p) => p.data.tags.forEach((t) => tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1)))
const tagsSorted = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "ja"))

const base = import.meta.env.BASE_URL
---

<Base title="DX Lab">
  <div class="page-layout">
    <div class="page-layout__spacer" aria-hidden="true"></div>
    <header class="page-layout__main">
      <h1>DX Lab</h1>
      <p class="tagline">DX推進 &times; AI活用で、業務をもっとシンプルに</p>
    </header>

    <div class="page-layout__spacer" aria-hidden="true"></div>
    <section class="about page-layout__main">
      <h2>About</h2>
      <p>
        大学職員である管理人が、AIやGoogle関連サービスなどを活用して、業務効率化の事例を紹介しています。
      </p>
    </section>

    <aside class="filters" aria-label="Tag filters">
      <div class="filters__inner">
        <p class="filters__title">Tags</p>
        <div class="tag-filter">
          <button class="filter-btn active" data-tag="all">すべて</button>
          {tagsSorted.map(([tag, count]) => (
            <button class="filter-btn" data-tag={tag}>
              <span>{tag}</span>
              <span class="filter-btn__count">{count}</span>
            </button>
          ))}
        </div>
      </div>
    </aside>

    <section class="projects page-layout__main">
      <div class="projects__header">
        <h2>Projects</h2>
      </div>

      <ul class="projects__list">
        {sorted.map((project) => (
          <li data-tags={JSON.stringify(project.data.tags)}>
            <a href={`${base}/projects/${project.id}/`}>
              <h3>{project.data.title}</h3>
              <time>{project.data.createdAt}</time>
              <p>{project.data.description}</p>
              <TagList tags={project.data.tags} />
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <style>
    .page-layout {
      display: grid;
      grid-template-columns: 200px minmax(0, 1fr);
      column-gap: 1.75rem;
      row-gap: 0;
      align-items: start;
    }

    .page-layout__spacer {
      min-height: 1px;
    }

    .page-layout__main {
      min-width: 0;
    }

    header {
      margin-bottom: 3rem;
    }

    h1 {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .tagline {
      margin-top: 0.5rem;
      color: var(--subtle);
      font-size: 1rem;
    }

    h2 {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 1rem;
      padding-bottom: 0.3rem;
      border-bottom: 1px solid var(--border);
    }

    section {
      margin-bottom: 2.5rem;
    }

    .about p {
      color: var(--muted);
    }

    .filters {
      position: sticky;
      top: 4.75rem;
      align-self: start;
    }

    .filters__inner {
      padding: 1rem;
      border-radius: 10px;
      background: var(--surface);
      box-shadow: var(--shadow);
    }

    .filters__title {
      margin-bottom: 0.85rem;
      color: var(--subtle);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .tag-filter {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .filter-btn {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      width: 100%;
      font-size: 0.8rem;
      padding: 0.55rem 0.7rem;
      background: var(--surface-muted);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--subtle);
      text-align: left;
      cursor: pointer;
      transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.2s;
    }

    .filter-btn:hover {
      background: var(--surface-hover);
      color: var(--text);
      border-color: var(--border-strong);
      transform: translateX(2px);
    }

    .filter-btn.active {
      background: var(--accent);
      color: var(--accent-contrast);
      border-color: var(--accent);
    }

    .filter-btn__count {
      flex-shrink: 0;
      font-size: 0.72rem;
      opacity: 0.85;
    }

    .projects__list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .projects__list li {
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
      box-shadow: var(--shadow);
      transition: border-color 0.2s, opacity 0.2s, background 0.2s;
    }

    .projects__list li.hidden {
      display: none;
    }

    .projects__list li:hover {
      border-color: var(--border-strong);
    }

    .projects__list a {
      display: block;
      padding: 1.2rem;
      text-decoration: none;
      color: inherit;
    }

    .projects__list h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0.3rem;
    }

    .projects__list time {
      font-size: 0.8rem;
      color: var(--subtle);
      display: block;
      margin-bottom: 0.4rem;
    }

    .projects__list p {
      font-size: 0.9rem;
      color: var(--muted);
      margin-bottom: 0.8rem;
    }

    @media (max-width: 920px) {
      .page-layout {
        grid-template-columns: 180px minmax(0, 1fr);
        column-gap: 1.25rem;
      }
    }

    @media (max-width: 720px) {
      .page-layout {
        grid-template-columns: 1fr;
      }

      .page-layout__spacer {
        display: none;
      }

      .filters {
        position: static;
        margin-bottom: 1rem;
      }

      .filters__inner {
        padding: 0;
        background: transparent;
        box-shadow: none;
      }

      .tag-filter {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        gap: 0.4rem;
      }

      .filter-btn {
        width: auto;
        padding: 0.3rem 0.6rem;
        transform: none;
      }

      .filter-btn:hover {
        transform: none;
      }
    }

    @media (max-width: 480px) {
      header {
        margin-bottom: 2rem;
      }

      h1 {
        font-size: 1.6rem;
      }

      .tagline {
        font-size: 0.9rem;
      }

      section {
        margin-bottom: 2rem;
      }

      .filters__title {
        margin-bottom: 0.6rem;
      }

      .filter-btn {
        font-size: 0.7rem;
        padding: 0.2rem 0.5rem;
      }

      .projects__list h3 {
        font-size: 0.95rem;
      }
    }
  </style>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn")
    const items = document.querySelectorAll<HTMLLIElement>(".projects__list li")

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tag = btn.dataset.tag
        buttons.forEach((b) => b.classList.remove("active"))
        btn.classList.add("active")

        items.forEach((item) => {
          if (tag === "all") {
            item.classList.remove("hidden")
            return
          }
          const tags: string[] = JSON.parse(item.dataset.tags ?? "[]")
          item.classList.toggle("hidden", !tags.includes(tag!))
        })
      })
    })
  </script>
</Base>
