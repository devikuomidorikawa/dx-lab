---
import { getCollection } from "astro:content"
import Base from "../layouts/Base.astro"
import TagList from "../components/TagList.astro"

const allProjects = await getCollection("projects")
const projects = allProjects.filter((p) => p.data.status !== "draft")
const sorted = [...projects].sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
const base = import.meta.env.BASE_URL
---

<Base title="DX Lab">
  <header>
    <h1>DX Lab</h1>
    <p class="tagline">DX推進 &times; AI活用で、業務をもっとシンプルに</p>
  </header>

  <section class="about">
    <h2>About</h2>
    <p>
      AIやGoogle関連サービスを利用して業務改善を行った事例を紹介しています。
    </p>
  </section>

  <section class="projects">
    <h2>Projects</h2>
    <ul>
      {sorted.map((project) => (
        <li>
          <a href={`${base}/projects/${project.id}/`}>
            <h3>{project.data.title}</h3>
            <p>{project.data.description}</p>
            <TagList tags={project.data.tags} />
          </a>
        </li>
      ))}
    </ul>
  </section>


  <style>
    header {
      margin-bottom: 3rem;
    }

    h1 {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .tagline {
      margin-top: 0.5rem;
      color: #666;
      font-size: 1rem;
    }

    h2 {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 1rem;
      padding-bottom: 0.3rem;
      border-bottom: 1px solid #eee;
    }

    section {
      margin-bottom: 2.5rem;
    }

    .about p {
      color: #555;
    }

    .projects ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .projects li {
      border: 1px solid #eee;
      border-radius: 8px;
      transition: border-color 0.2s;
    }

    .projects li:hover {
      border-color: #ccc;
    }

    .projects a {
      display: block;
      padding: 1.2rem;
      text-decoration: none;
      color: inherit;
    }

    .projects h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0.4rem;
    }

    .projects p {
      font-size: 0.9rem;
      color: #555;
      margin-bottom: 0.8rem;
    }

  </style>
</Base>
