---
import { getCollection } from "astro:content"
import Base from "../layouts/Base.astro"
import LikeButton from "../components/LikeButton.astro"
import TagList from "../components/TagList.astro"
import { withResolvedProjectDates } from "../lib/projectDates"

const ALL_TAG = "all"

function getPublishedProjects(projects: Awaited<ReturnType<typeof getCollection<"projects">>>) {
  return projects.filter((project) => project.data.status !== "draft")
}

function sortProjectsByDate(projects: ReturnType<typeof getPublishedProjects>) {
  return [...projects].sort((left, right) => right.data.createdAt.localeCompare(left.data.createdAt))
}

function sortFeaturedProjects(projects: ReturnType<typeof getPublishedProjects>) {
  return [...projects].sort(
    (left, right) =>
      (left.data.order ?? Number.MAX_SAFE_INTEGER) - (right.data.order ?? Number.MAX_SAFE_INTEGER) ||
      right.data.createdAt.localeCompare(left.data.createdAt),
  )
}

function buildTagSummary(projects: ReturnType<typeof getPublishedProjects>) {
  const counts = new Map<string, number>()

  projects.forEach((project) => {
    project.data.tags.forEach((tag) => {
      counts.set(tag, (counts.get(tag) ?? 0) + 1)
    })
  })

  return [...counts.entries()].sort((left, right) => right[1] - left[1] || left[0].localeCompare(right[0], "ja"))
}

const allProjects = await getCollection("projects")
const projects = getPublishedProjects(allProjects).map(withResolvedProjectDates)
const featuredProjects = sortFeaturedProjects(projects.filter((project) => project.data.featured))
const sortedProjects = sortProjectsByDate(projects.filter((project) => !project.data.featured))
const tagSummary = buildTagSummary(projects)

const base = import.meta.env.BASE_URL
---

<Base title="DX Lab">
  <header class="hero">
    <h1>DX Lab</h1>
    <p class="tagline">DX推進 × AI活用で、業務をもっとシンプルに</p>
  </header>

  <section class="about">
    <h2>このページについて</h2>
    <p>
      大学職員である管理人が、AIやGoogle関連サービスなどを活用して、業務効率化の事例を紹介しています。
    </p>
  </section>

  <section class="projects">
    <h2>記事</h2>

    {featuredProjects.length > 0 && (
      <div class="featured-projects" aria-label="注目記事">
        <p class="featured-projects__title">Featured</p>
        <ul class="projects__list projects__list--featured">
          {featuredProjects.map((project) => (
            <li data-tags={JSON.stringify(project.data.tags)} data-search-text={`${project.data.title} ${project.data.description} ${project.data.tags.join(" ")}`}>
              <a href={`${base}/projects/${project.id}/`}>
                <div class="project-heading">
                  <h3>{project.data.title}</h3>
                  {project.data.highlightUpdated && <span class="project-badge">Updated</span>}
                </div>
                <div class="project-meta" aria-label="記事情報">
                  <span>作成日: {project.data.createdAt}</span>
                  <span>最終更新日: {project.data.updatedAt}</span>
                </div>
                <p>{project.data.description}</p>
                <TagList tags={project.data.tags} />
              </a>
              <div class="card-actions">
                <LikeButton articleSlug={project.id} articleTitle={project.data.title} compact />
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="projects__shell">
      <aside class="filters" aria-label="Tag filters">
        <div class="filters__inner">
          <label class="site-search" for="site-search-input">
            <span class="sr-only">サイト内検索</span>
            <input
              id="site-search-input"
              class="site-search__input"
              type="search"
              placeholder="サイト内検索"
              autocomplete="off"
              spellcheck="false"
            />
          </label>
          <p class="filters__title">タグ</p>
          <div class="tag-filter">
            <button class="filter-btn active" type="button" data-tag={ALL_TAG}>すべて</button>
            {tagSummary.map(([tag, count]) => (
              <button class="filter-btn" type="button" data-tag={tag}>
                <span>{tag}</span>
                <span class="filter-btn__count">{count}</span>
              </button>
            ))}
          </div>
        </div>
      </aside>

      <ul class="projects__list">
        {sortedProjects.map((project) => (
          <li data-tags={JSON.stringify(project.data.tags)} data-search-text={`${project.data.title} ${project.data.description} ${project.data.tags.join(" ")}`}>
            <a href={`${base}/projects/${project.id}/`}>
              <div class="project-heading">
                <h3>{project.data.title}</h3>
                {project.data.highlightUpdated && <span class="project-badge">Updated</span>}
              </div>
              <div class="project-meta" aria-label="記事情報">
                <span>作成日: {project.data.createdAt}</span>
                <span>最終更新日: {project.data.updatedAt}</span>
              </div>
              <p>{project.data.description}</p>
              <TagList tags={project.data.tags} />
            </a>
            <div class="card-actions">
              <LikeButton articleSlug={project.id} articleTitle={project.data.title} compact />
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    .projects {
      --sidebar-width: 200px;
      --shell-gap: 1.75rem;
      --card-gap: 1.25rem;
    }

    .hero {
      margin-bottom: 3rem;
    }

    h1 {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .tagline {
      margin-top: 0.5rem;
      color: var(--subtle);
      font-size: 1rem;
    }

    h2 {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 1rem;
      padding-bottom: 0.3rem;
      border-bottom: 1px solid var(--border);
    }

    section {
      margin-bottom: 2.5rem;
    }

    .about p,
    .projects__list p {
      color: var(--muted);
    }

    .projects__shell {
      display: grid;
      grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
      gap: var(--shell-gap);
      align-items: start;
    }

    .featured-projects {
      margin-bottom: 1.5rem;
    }

    .featured-projects__title {
      margin-bottom: 0.75rem;
      color: var(--subtle);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .projects__list--featured {
      margin-bottom: 0;
    }

    .filters {
      position: sticky;
      top: 4.75rem;
      align-self: start;
    }

    .filters__inner {
      box-sizing: border-box;
      padding: 0.25rem 0.85rem 0.25rem 0;
      border-right: 1px solid var(--border);
      max-height: calc(100vh - 6rem);
      overflow: hidden;
      overscroll-behavior: contain;
      scrollbar-gutter: stable;
      transition: background 0.18s ease, border-color 0.18s ease, padding 0.18s ease;
    }

    .filters:hover .filters__inner,
    .filters:focus-within .filters__inner {
      box-sizing: border-box;
      padding-right: 0.95rem;
      background: var(--surface);
      overflow-y: auto;
      border-right-color: var(--border-strong);
    }

    .filters__title {
      margin-bottom: 0.85rem;
      color: var(--subtle);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .site-search {
      display: block;
      margin-bottom: 0.85rem;
      margin-left: 0.35rem;
      width: calc(100% - 0.35rem);
    }

    .site-search__input {
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
      padding: 0.55rem 0.7rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--surface-muted);
      color: var(--text);
      font: inherit;
      font-size: 0.8rem;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
    }

    .site-search__input::placeholder {
      color: var(--subtle);
    }

    .site-search__input:hover,
    .site-search__input:focus-visible {
      background: var(--surface-hover);
      border-color: var(--border-strong);
    }

    .site-search__input:focus-visible {
      outline: 2px solid var(--text);
      outline-offset: 2px;
    }

    .tag-filter {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding-right: 0.2rem;
    }

    .filter-btn {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      width: 100%;
      font-size: 0.8rem;
      padding: 0.55rem 0.7rem;
      background: var(--surface-muted);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--subtle);
      text-align: left;
      cursor: pointer;
      transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.2s;
    }

    .filter-btn:hover {
      background: var(--surface-hover);
      color: var(--text);
      border-color: var(--border-strong);
      transform: none;
    }

    .filter-btn.active {
      background: var(--accent);
      color: var(--accent-contrast);
      border-color: var(--accent);
    }

    .filter-btn.is-hidden {
      display: none;
    }

    .filter-btn__count {
      flex-shrink: 0;
      font-size: 0.72rem;
      opacity: 0.85;
    }

    .projects__list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--card-gap);
      min-width: 0;
    }

    .projects__list li {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
      box-shadow: var(--shadow);
      transition: border-color 0.2s, opacity 0.2s, background 0.2s;
    }

    .projects__list li.hidden {
      display: none;
    }

    .projects__list li:hover {
      border-color: var(--border-strong);
    }

    .projects__list a {
      display: block;
      flex: 1 1 auto;
      padding: 1.2rem;
      text-decoration: none;
      color: inherit;
    }

    .card-actions {
      display: flex;
      justify-content: flex-end;
      padding: 0 1.2rem 1.2rem;
    }

    .project-heading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      margin-bottom: 0.3rem;
    }

    .projects__list h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0;
    }

    .project-badge {
      flex-shrink: 0;
      padding: 0.18rem 0.45rem;
      border-radius: 999px;
      background: var(--surface-muted);
      border: 1px solid var(--border);
      color: var(--subtle);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .project-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 1rem;
      font-size: 0.8rem;
      color: var(--subtle);
      margin-bottom: 0.4rem;
    }

    .projects__list p {
      font-size: 0.9rem;
      margin-bottom: 0.8rem;
    }

    @media (max-width: 920px) {
      .projects {
        --sidebar-width: 180px;
        --shell-gap: 1.25rem;
      }
    }

    @media (max-width: 720px) {
      .projects__shell {
        grid-template-columns: 1fr;
      }

      .filters {
        position: static;
      }

      .filters__inner {
        padding: 0;
        background: transparent;
        box-shadow: none;
        max-height: none;
        overflow: visible;
        overscroll-behavior: auto;
        scrollbar-gutter: auto;
        border-right: none;
      }

      .tag-filter {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 1rem;
        padding-right: 0;
      }

      .filter-btn {
        width: auto;
        padding: 0.3rem 0.6rem;
        transform: none;
      }

      .filter-btn:hover {
        transform: none;
      }

      .site-search {
        margin-left: 0;
        width: 100%;
      }
    }

    @media (max-width: 480px) {
      .hero {
        margin-bottom: 2rem;
      }

      h1 {
        font-size: 1.6rem;
      }

      .tagline {
        font-size: 0.9rem;
      }

      section {
        margin-bottom: 2rem;
      }

      .filters__title {
        margin-bottom: 0.6rem;
      }

      .filter-btn {
        font-size: 0.7rem;
        padding: 0.2rem 0.5rem;
      }

      .projects__list h3 {
        font-size: 0.95rem;
      }
    }
  </style>

  <script>
    (() => {
      const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-btn"))
      const projectItems = Array.from(document.querySelectorAll<HTMLLIElement>(".projects__list li[data-tags]"))
      const siteSearchInput = document.querySelector<HTMLInputElement>(".site-search__input")
      const allTag = "all"

      if (filterButtons.length === 0 || projectItems.length === 0) return

      const normalize = (value: string) => value.normalize("NFKC").toLocaleLowerCase().trim()
      let selectedTag = allTag
      let searchQuery = ""

      const setActiveFilter = (tag: string) => {
        selectedTag = tag
        filterButtons.forEach((button) => {
          button.classList.toggle("active", button.dataset.tag === tag)
        })
      }

      const applyVisibleState = () => {
        projectItems.forEach((item) => {
          const tags: string[] = JSON.parse(item.dataset.tags ?? "[]")
          const matchesTag = selectedTag === allTag || tags.includes(selectedTag)
          const haystack = normalize(item.dataset.searchText ?? "")
          const matchesSearch = searchQuery.length === 0 || haystack.includes(normalize(searchQuery))
          item.classList.toggle("hidden", !(matchesTag && matchesSearch))
        })
      }

      const applySiteSearch = (query: string) => {
        searchQuery = query
        applyVisibleState()
      }

      const applyTagFilter = (tag: string) => {
        selectedTag = tag
        searchQuery = ""
        if (siteSearchInput) {
          siteSearchInput.value = ""
        }
        applyVisibleState()
      }

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const tag = button.dataset.tag ?? allTag
          setActiveFilter(tag)
          applyTagFilter(tag)
        })
      })

      const handleSiteSearch = () => applySiteSearch(siteSearchInput?.value ?? "")

      siteSearchInput?.addEventListener("input", handleSiteSearch)
      siteSearchInput?.addEventListener("search", handleSiteSearch)
      siteSearchInput?.addEventListener("keyup", handleSiteSearch)

      handleSiteSearch()
      applyVisibleState()
    })()
  </script>
</Base>
