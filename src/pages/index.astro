---
import { getCollection } from "astro:content"
import Base from "../layouts/Base.astro"
import TagList from "../components/TagList.astro"

const allProjects = await getCollection("projects")
const projects = allProjects.filter((p) => p.data.status !== "draft")
const sorted = [...projects].sort((a, b) => b.data.createdAt.localeCompare(a.data.createdAt))

const tagCounts = new Map<string, number>()
projects.forEach((p) => p.data.tags.forEach((t) => tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1)))
const tagsSorted = [...tagCounts.entries()].sort((a, b) => b[1] - a[1])

const base = import.meta.env.BASE_URL
---

<Base title="DX Lab">
  <header>
    <h1>DX Lab</h1>
    <p class="tagline">DX推進 &times; AI活用で、業務をもっとシンプルに</p>
  </header>

  <section class="about">
    <h2>About</h2>
    <p>
      AIやGoogle関連サービスを利用して業務改善を行った事例を紹介しています。
    </p>
  </section>

  <section class="projects">
    <h2>Projects</h2>

    <div class="tag-filter">
      <button class="filter-btn active" data-tag="all">すべて</button>
      {tagsSorted.map(([tag, count]) => (
        <button class="filter-btn" data-tag={tag}>{tag} ({count})</button>
      ))}
    </div>

    <ul>
      {sorted.map((project) => (
        <li data-tags={JSON.stringify(project.data.tags)}>
          <a href={`${base}/projects/${project.id}/`}>
            <h3>{project.data.title}</h3>
            <time>{project.data.createdAt}</time>
            <p>{project.data.description}</p>
            <TagList tags={project.data.tags} />
          </a>
        </li>
      ))}
    </ul>
  </section>

  <style>
    header {
      margin-bottom: 3rem;
    }

    h1 {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .tagline {
      margin-top: 0.5rem;
      color: #666;
      font-size: 1rem;
    }

    h2 {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 1rem;
      padding-bottom: 0.3rem;
      border-bottom: 1px solid #eee;
    }

    section {
      margin-bottom: 2.5rem;
    }

    .about p {
      color: #555;
    }

    .tag-filter {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-bottom: 1.5rem;
    }

    .filter-btn {
      font-size: 0.75rem;
      padding: 0.25rem 0.7rem;
      background: #f5f5f5;
      border: 1px solid transparent;
      border-radius: 4px;
      color: #666;
      cursor: pointer;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
    }

    .filter-btn:hover {
      background: #e8e8e8;
      color: #333;
    }

    .filter-btn.active {
      background: #333;
      color: #fff;
      border-color: #333;
    }

    .projects ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .projects li {
      border: 1px solid #eee;
      border-radius: 8px;
      transition: border-color 0.2s, opacity 0.2s;
    }

    .projects li.hidden {
      display: none;
    }

    .projects li:hover {
      border-color: #ccc;
    }

    .projects a {
      display: block;
      padding: 1.2rem;
      text-decoration: none;
      color: inherit;
    }

    .projects h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0.3rem;
    }

    .projects time {
      font-size: 0.8rem;
      color: #888;
      display: block;
      margin-bottom: 0.4rem;
    }

    .projects p {
      font-size: 0.9rem;
      color: #555;
      margin-bottom: 0.8rem;
    }
  </style>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
    const items = document.querySelectorAll<HTMLLIElement>('.projects li')

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag
        buttons.forEach((b) => b.classList.remove('active'))
        btn.classList.add('active')

        items.forEach((item) => {
          if (tag === 'all') {
            item.classList.remove('hidden')
            return
          }
          const tags: string[] = JSON.parse(item.dataset.tags ?? '[]')
          item.classList.toggle('hidden', !tags.includes(tag!))
        })
      })
    })
  </script>
</Base>
