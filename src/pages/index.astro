---
import { getCollection } from "astro:content"
import Base from "../layouts/Base.astro"
import TagList from "../components/TagList.astro"
import { withResolvedProjectDates } from "../lib/projectDates"

const ALL_TAG = "all"

function getPublishedProjects(projects: Awaited<ReturnType<typeof getCollection<"projects">>>) {
  return projects.filter((project) => project.data.status !== "draft")
}

function sortProjectsByDate(projects: ReturnType<typeof getPublishedProjects>) {
  return [...projects].sort((left, right) => right.data.createdAt.localeCompare(left.data.createdAt))
}

function sortFeaturedProjects(projects: ReturnType<typeof getPublishedProjects>) {
  return [...projects].sort(
    (left, right) =>
      (left.data.order ?? Number.MAX_SAFE_INTEGER) - (right.data.order ?? Number.MAX_SAFE_INTEGER) ||
      right.data.createdAt.localeCompare(left.data.createdAt),
  )
}

function buildTagSummary(projects: ReturnType<typeof getPublishedProjects>) {
  const counts = new Map<string, number>()

  projects.forEach((project) => {
    project.data.tags.forEach((tag) => {
      counts.set(tag, (counts.get(tag) ?? 0) + 1)
    })
  })

  return [...counts.entries()].sort((left, right) => right[1] - left[1] || left[0].localeCompare(right[0], "ja"))
}

const allProjects = await getCollection("projects")
const projects = getPublishedProjects(allProjects).map(withResolvedProjectDates)
const featuredProjects = sortFeaturedProjects(projects.filter((project) => project.data.featured))
const sortedProjects = sortProjectsByDate(projects.filter((project) => !project.data.featured))
const tagSummary = buildTagSummary(projects)

const base = import.meta.env.BASE_URL
---

<Base title="DX Lab">
  <header class="hero">
    <h1>DX Lab</h1>
    <p class="tagline">DX推進 &times; AI活用で、業務をもっとシンプルに</p>
  </header>

  <section class="about">
    <h2>About</h2>
    <p>
      大学職員である管理人が、AIやGoogle関連サービスなどを活用して、業務効率化の事例を紹介しています。
    </p>
  </section>

  <section class="projects">
    <h2>Projects</h2>

    {featuredProjects.length > 0 && (
      <div class="featured-projects" aria-label="注目記事">
        <p class="featured-projects__title">Featured</p>
        <ul class="projects__list projects__list--featured">
          {featuredProjects.map((project) => (
            <li>
              <a href={`${base}/projects/${project.id}/`}>
                <div class="project-heading">
                  <h3>{project.data.title}</h3>
                  {project.data.highlightUpdated && <span class="project-badge">Updated</span>}
                </div>
                <div class="project-meta" aria-label="記事情報">
                  <span>作成日: {project.data.createdAt}</span>
                  <span>最終更新日: {project.data.updatedAt}</span>
                </div>
                <p>{project.data.description}</p>
                <TagList tags={project.data.tags} />
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="projects__shell">
      <aside class="filters" aria-label="Tag filters">
        <div class="filters__inner">
          <p class="filters__title">Tags</p>
          <div class="tag-filter">
            <button class="filter-btn active" data-tag={ALL_TAG}>すべて</button>
            {tagSummary.map(([tag, count]) => (
              <button class="filter-btn" data-tag={tag}>
                <span>{tag}</span>
                <span class="filter-btn__count">{count}</span>
              </button>
            ))}
          </div>
        </div>
      </aside>

      <ul class="projects__list">
        {sortedProjects.map((project) => (
          <li data-tags={JSON.stringify(project.data.tags)}>
            <a href={`${base}/projects/${project.id}/`}>
              <div class="project-heading">
                <h3>{project.data.title}</h3>
                {project.data.highlightUpdated && <span class="project-badge">Updated</span>}
              </div>
              <div class="project-meta" aria-label="記事情報">
                <span>作成日: {project.data.createdAt}</span>
                <span>最終更新日: {project.data.updatedAt}</span>
              </div>
              <p>{project.data.description}</p>
              <TagList tags={project.data.tags} />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    .projects {
      --sidebar-width: 200px;
      --shell-gap: 1.75rem;
      --card-gap: 1.25rem;
    }

    .hero {
      margin-bottom: 3rem;
    }

    h1 {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .tagline {
      margin-top: 0.5rem;
      color: var(--subtle);
      font-size: 1rem;
    }

    h2 {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 1rem;
      padding-bottom: 0.3rem;
      border-bottom: 1px solid var(--border);
    }

    section {
      margin-bottom: 2.5rem;
    }

    .about p,
    .projects__list p {
      color: var(--muted);
    }

    .projects__shell {
      display: grid;
      grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
      gap: var(--shell-gap);
      align-items: start;
    }

    .featured-projects {
      margin-bottom: 1.5rem;
    }

    .featured-projects__title {
      margin-bottom: 0.75rem;
      color: var(--subtle);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .projects__list--featured {
      margin-bottom: 0;
    }

    .filters {
      position: sticky;
      top: 4.75rem;
      align-self: start;
    }

    .filters__inner {
      padding: 1rem;
      background: var(--surface);
      border-radius: 10px;
      box-shadow: var(--shadow);
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
      overscroll-behavior: contain;
      scrollbar-gutter: stable;
    }

    .filters__title {
      margin-bottom: 0.85rem;
      color: var(--subtle);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .tag-filter {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .filter-btn {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      width: 100%;
      font-size: 0.8rem;
      padding: 0.55rem 0.7rem;
      background: var(--surface-muted);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--subtle);
      text-align: left;
      cursor: pointer;
      transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.2s;
    }

    .filter-btn:hover {
      background: var(--surface-hover);
      color: var(--text);
      border-color: var(--border-strong);
      transform: translateX(2px);
    }

    .filter-btn.active {
      background: var(--accent);
      color: var(--accent-contrast);
      border-color: var(--accent);
    }

    .filter-btn__count {
      flex-shrink: 0;
      font-size: 0.72rem;
      opacity: 0.85;
    }

    .projects__list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--card-gap);
      min-width: 0;
    }

    .projects__list li {
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
      box-shadow: var(--shadow);
      transition: border-color 0.2s, opacity 0.2s, background 0.2s;
    }

    .projects__list li.hidden {
      display: none;
    }

    .projects__list li:hover {
      border-color: var(--border-strong);
    }

    .projects__list a {
      display: block;
      padding: 1.2rem;
      text-decoration: none;
      color: inherit;
    }

    .project-heading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      margin-bottom: 0.3rem;
    }

    .projects__list h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0;
    }

    .project-badge {
      flex-shrink: 0;
      padding: 0.18rem 0.45rem;
      border-radius: 999px;
      background: var(--surface-muted);
      border: 1px solid var(--border);
      color: var(--subtle);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .project-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 1rem;
      font-size: 0.8rem;
      color: var(--subtle);
      margin-bottom: 0.4rem;
    }

    .projects__list p {
      font-size: 0.9rem;
      margin-bottom: 0.8rem;
    }

    @media (max-width: 920px) {
      .projects {
        --sidebar-width: 180px;
        --shell-gap: 1.25rem;
      }
    }

    @media (max-width: 720px) {
      .projects__shell {
        grid-template-columns: 1fr;
      }

      .filters {
        position: static;
      }

      .filters__inner {
        padding: 0;
        background: transparent;
        box-shadow: none;
        max-height: none;
        overflow: visible;
        overscroll-behavior: auto;
        scrollbar-gutter: auto;
      }

      .tag-filter {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 1rem;
      }

      .filter-btn {
        width: auto;
        padding: 0.3rem 0.6rem;
        transform: none;
      }

      .filter-btn:hover {
        transform: none;
      }
    }

    @media (max-width: 480px) {
      .hero {
        margin-bottom: 2rem;
      }

      h1 {
        font-size: 1.6rem;
      }

      .tagline {
        font-size: 0.9rem;
      }

      section {
        margin-bottom: 2rem;
      }

      .filters__title {
        margin-bottom: 0.6rem;
      }

      .filter-btn {
        font-size: 0.7rem;
        padding: 0.2rem 0.5rem;
      }

      .projects__list h3 {
        font-size: 0.95rem;
      }
    }
  </style>

  <script>
    (() => {
      const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-btn"))
      const projectItems = Array.from(document.querySelectorAll<HTMLLIElement>(".projects__list li"))

      if (filterButtons.length === 0 || projectItems.length === 0) return

      const setActiveFilter = (selectedTag: string) => {
        filterButtons.forEach((button) => {
          button.classList.toggle("active", button.dataset.tag === selectedTag)
        })
      }

      const applyTagFilter = (selectedTag: string) => {
        projectItems.forEach((item) => {
          if (selectedTag === ALL_TAG) {
            item.classList.remove("hidden")
            return
          }

          const tags: string[] = JSON.parse(item.dataset.tags ?? "[]")
          item.classList.toggle("hidden", !tags.includes(selectedTag))
        })
      }

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const selectedTag = button.dataset.tag ?? ALL_TAG
          setActiveFilter(selectedTag)
          applyTagFilter(selectedTag)
        })
      })
    })()
  </script>
</Base>
