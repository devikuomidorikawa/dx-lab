---
import { getCollection, render } from "astro:content"
import Base from "../../layouts/Base.astro"
import TagList from "../../components/TagList.astro"
import LikeButton from "../../components/LikeButton.astro"
import { resolveProjectUpdatedAt } from "../../lib/projectDates"

export async function getStaticPaths() {
  const projects = await getCollection("projects")
  return projects
    .filter((p) => p.data.status !== "draft")
    .map((project) => ({
      params: { id: project.id },
      props: { project },
    }))
}

const { project } = Astro.props
const resolvedUpdatedAt = resolveProjectUpdatedAt(project)
const { Content, headings } = await render(project)
const base = import.meta.env.BASE_URL

const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3)
const headingItems = tocHeadings.map((heading) => ({
  ...heading,
  id: heading.slug,
}))
---

<Base title={`${project.data.title} | DX Lab`} description={project.data.description} ogType="article">
  <nav class="back">
    <a href={`${base}/`}>&larr; トップに戻る</a>
  </nav>

  <article class="article-layout" id="article-top">
    {headingItems.length > 0 && (
      <aside class="toc-shell" aria-label="目次">
        <nav class="toc">
          <p class="toc__title">目次</p>
          <ol class="toc__list">
            {headingItems.map((heading) => (
              <li class:list={["toc__item", `toc__item--depth-${heading.depth}`]}>
                <a href={`#${heading.id}`}>
                  <span class="toc__text">{heading.text}</span>
                </a>
              </li>
            ))}
          </ol>
          <div class="toc__actions">
            <LikeButton articleSlug={project.id} articleTitle={project.data.title} />
            <a class="toc__button" href={`${base}/`}>トップページに戻る</a>
            <a class="toc__button" href="#article-top">記事の最上部へ</a>
          </div>
        </nav>
      </aside>
    )}

    <div class="article-main">
      <h1>{project.data.title}</h1>
      <div class="meta">
        <span>作成日: {project.data.createdAt}</span>
        <span>最終更新日: {resolvedUpdatedAt}</span>
      </div>
      <TagList tags={project.data.tags} linked />
      <div class="content">
        <Content />
      </div>
    </div>
  </article>

  <style>
    .back {
      margin-bottom: 2rem;
    }

    .back a {
      color: var(--subtle);
      text-decoration: none;
      font-size: 0.9rem;
    }

    .back a:hover {
      color: var(--text);
    }

    .article-layout {
      display: grid;
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 1.75rem;
      align-items: start;
    }

    .toc-shell {
      position: sticky;
      top: 4.75rem;
      align-self: start;
    }

    .toc {
      padding: 0.25rem 0.85rem 0.25rem 0;
      border-right: 1px solid var(--border);
      max-height: calc(100vh - 6rem);
      overflow: hidden;
      overscroll-behavior: contain;
      scrollbar-gutter: stable;
      transition: background 0.18s ease, border-color 0.18s ease, padding 0.18s ease;
    }

    .toc-shell:hover .toc,
    .toc-shell:focus-within .toc {
      padding-right: 0.95rem;
      background: var(--surface);
      overflow-y: auto;
      border-right-color: var(--border-strong);
    }

    .toc__title {
      margin-bottom: 0.85rem;
      color: var(--subtle);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .toc__list {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .toc__item a {
      display: flex;
      align-items: flex-start;
      gap: 0.3rem;
      color: var(--text);
      text-decoration: none;
      font-size: 0.9rem;
      line-height: 1.45;
    }

    .toc__item a:hover {
      color: var(--accent);
    }

    .toc__text {
      min-width: 0;
    }

    .toc__item--depth-3 {
      padding-left: 1rem;
      font-size: 0.86rem;
    }

    .toc__actions {
      display: grid;
      gap: 0.5rem;
      margin-top: 1rem;
      padding-top: 0.85rem;
      border-top: 1px solid var(--border);
    }

    .toc__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2rem;
      padding: 0.35rem 0.65rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface-muted);
      color: var(--text);
      text-decoration: none;
      font-size: 0.84rem;
      font-weight: 600;
    }

    .toc__button:hover {
      background: var(--surface-hover);
      border-color: var(--border-strong);
    }

    .article-main {
      min-width: 0;
    }

    h1 {
      font-size: 1.6rem;
      font-weight: 700;
      margin-bottom: 0.8rem;
    }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 1.2rem;
      font-size: 0.8rem;
      color: var(--subtle);
      margin-bottom: 0.8rem;
    }

    .article-main > :global(.tags) {
      margin-bottom: 2rem;
    }

    .article-main > :global(.reaction-bar) {
      display: flex;
      justify-content: flex-end;
      width: 100%;
      margin-top: 1.4rem;
      margin-bottom: 1.4rem;
    }

    .content {
      border-top: 1px solid var(--border);
      padding-top: 1.8rem;
    }

    .content :global(.mermaid) {
      margin-bottom: 1rem;
      text-align: center;
      background: var(--surface);
      padding: 1rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      overflow-x: auto;
    }

    .content :global(h2) {
      font-size: 1.2rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.8rem;
      padding-bottom: 0.3rem;
      border-bottom: 1px solid var(--border);
    }

    .content :global(h3) {
      font-size: 1.05rem;
      font-weight: 600;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
      padding-left: 0.7rem;
    }

    .content :global(p) {
      margin-bottom: 1rem;
      color: var(--muted);
    }

    .content :global(ol),
    .content :global(ul) {
      margin-bottom: 1rem;
      padding-left: 1.5rem;
      color: var(--muted);
    }

    .content :global(li) {
      margin-bottom: 0.3rem;
    }

    .content :global(strong) {
      color: var(--text);
    }

    .content :global(code) {
      font-size: 0.85rem;
      background: var(--surface-muted);
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
    }

    .content :global(.code-block) {
      position: relative;
      margin-bottom: 1rem;
    }

    .content :global(.copy-btn) {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      background: var(--accent);
      color: var(--accent-contrast);
      border: none;
      border-radius: 4px;
      padding: 0.25rem 0.5rem;
      font-size: 0.75rem;
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .content :global(.copy-btn:hover) {
      opacity: 0.88;
    }

    .content :global(.copy-btn.copied) {
      background: var(--success);
      color: #ffffff;
    }

    .content :global(pre) {
      background: var(--code-bg);
      color: var(--code-text);
      padding: 1rem 1.2rem;
      border-radius: 6px;
      overflow-x: auto;
    }

    .content :global(pre code) {
      background: none;
      padding: 0;
      color: inherit;
      font-size: 0.85rem;
    }

    .content :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1rem;
      font-size: 0.9rem;
    }

    .content :global(th),
    .content :global(td) {
      border: 1px solid var(--border);
      padding: 0.5rem 0.8rem;
      text-align: left;
    }

    .content :global(th) {
      background: var(--surface-muted);
      font-weight: 600;
    }

    @media (max-width: 480px) {
      .article-layout {
        grid-template-columns: 1fr;
      }

      .toc-shell {
        position: static;
      }

      .toc {
        padding: 0;
        border-right: none;
        max-height: none;
        overflow: visible;
      }

      .toc__actions {
        border-top: none;
        padding-top: 0.5rem;
      }

      h1 {
        font-size: 1.3rem;
      }

      .meta {
        flex-direction: column;
        gap: 0.2rem;
      }

      .content :global(h3) {
        padding-left: 0.5rem;
      }

      .content :global(h2) {
        font-size: 1.1rem;
        margin-top: 1.5rem;
      }

      .content :global(h3) {
        font-size: 1rem;
      }

      .content :global(pre) {
        padding: 0.8rem;
        font-size: 0.8rem;
        border-radius: 4px;
      }

      .content :global(pre code) {
        font-size: 0.8rem;
      }

      .content :global(table) {
        font-size: 0.8rem;
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }

      .content :global(th),
      .content :global(td) {
        padding: 0.4rem 0.6rem;
      }
    }
  </style>

  <script>
    document.querySelectorAll(".content pre").forEach((pre) => {
      const code = pre.querySelector("code")

      if (pre.getAttribute("data-language") === "mermaid") {
        const mermaidDiv = document.createElement("div")
        mermaidDiv.className = "mermaid"
        mermaidDiv.textContent = code?.textContent ?? ""
        pre.parentNode?.replaceChild(mermaidDiv, pre)
        return
      }

      const wrapper = document.createElement("div")
      wrapper.className = "code-block"
      pre.parentNode?.insertBefore(wrapper, pre)
      wrapper.appendChild(pre)

      const btn = document.createElement("button")
      btn.className = "copy-btn"
      btn.textContent = "コピー"
      wrapper.appendChild(btn)

      btn.addEventListener("click", () => {
        const text = code?.textContent ?? pre.textContent ?? ""
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = "コピー済み"
          btn.classList.add("copied")
          setTimeout(() => {
            btn.textContent = "コピー"
            btn.classList.remove("copied")
          }, 2000)
        })
      })
    })

    if (document.querySelector(".mermaid")) {
      const script = document.createElement("script")
      const isDark = document.documentElement.dataset.theme === "dark"
      script.type = "module"
      script.textContent = `
        import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
        mermaid.initialize({ startOnLoad: true, theme: '${isDark ? "dark" : "neutral"}', fontFamily: 'system-ui, sans-serif' });
      `
      document.body.appendChild(script)
    }
  </script>
</Base>
