---
import { getCollection, render } from "astro:content"
import Base from "../../layouts/Base.astro"
import TagList from "../../components/TagList.astro"

export async function getStaticPaths() {
  const projects = await getCollection("projects")
  return projects
    .filter((p) => p.data.status !== "draft")
    .map((project) => ({
      params: { id: project.id },
      props: { project },
    }))
}

const { project } = Astro.props
const { Content } = await render(project)
const base = import.meta.env.BASE_URL
---

<Base title={`${project.data.title} | DX Lab`} description={project.data.description} ogType="article">
  <nav class="back">
    <a href={`${base}/`}>&larr; トップに戻る</a>
  </nav>

  <article>
    <h1>{project.data.title}</h1>
    <div class="meta">
      <span>公開日: {project.data.createdAt}</span>
      {project.data.createdAt !== project.data.updatedAt && (
        <span>更新日: {project.data.updatedAt}</span>
      )}
    </div>
    <TagList tags={project.data.tags} linked />
    <div class="content">
      <Content />
    </div>
  </article>

  <style>
    .back {
      margin-bottom: 2rem;
    }

    .back a {
      color: var(--subtle);
      text-decoration: none;
      font-size: 0.9rem;
    }

    .back a:hover {
      color: var(--text);
    }

    h1 {
      font-size: 1.6rem;
      font-weight: 700;
      margin-bottom: 0.8rem;
    }

    .meta {
      display: flex;
      gap: 1.2rem;
      font-size: 0.8rem;
      color: var(--subtle);
      margin-bottom: 0.8rem;
    }

    article > :global(.tags) {
      margin-bottom: 2rem;
    }

    .content {
      border-top: 1px solid var(--border);
      padding-top: 1.8rem;
    }

    .content :global(.mermaid) {
      margin-bottom: 1rem;
      text-align: center;
      background: var(--surface);
      padding: 1rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      overflow-x: auto;
    }

    .content :global(h2) {
      font-size: 1.2rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.8rem;
      padding-bottom: 0.3rem;
      border-bottom: 1px solid var(--border);
    }

    .content :global(h3) {
      font-size: 1.05rem;
      font-weight: 600;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .content :global(p) {
      margin-bottom: 1rem;
      color: var(--muted);
    }

    .content :global(ol),
    .content :global(ul) {
      margin-bottom: 1rem;
      padding-left: 1.5rem;
      color: var(--muted);
    }

    .content :global(li) {
      margin-bottom: 0.3rem;
    }

    .content :global(strong) {
      color: var(--text);
    }

    .content :global(code) {
      font-size: 0.85rem;
      background: var(--surface-muted);
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
    }

    .content :global(.code-block) {
      position: relative;
      margin-bottom: 1rem;
    }

    .content :global(.copy-btn) {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      background: var(--accent);
      color: var(--accent-contrast);
      border: none;
      border-radius: 4px;
      padding: 0.25rem 0.5rem;
      font-size: 0.75rem;
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .content :global(.copy-btn:hover) {
      opacity: 0.88;
    }

    .content :global(.copy-btn.copied) {
      background: var(--success);
      color: #ffffff;
    }

    .content :global(pre) {
      background: var(--code-bg);
      color: var(--code-text);
      padding: 1rem 1.2rem;
      border-radius: 6px;
      overflow-x: auto;
    }

    .content :global(pre code) {
      background: none;
      padding: 0;
      color: inherit;
      font-size: 0.85rem;
    }

    .content :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1rem;
      font-size: 0.9rem;
    }

    .content :global(th),
    .content :global(td) {
      border: 1px solid var(--border);
      padding: 0.5rem 0.8rem;
      text-align: left;
    }

    .content :global(th) {
      background: var(--surface-muted);
      font-weight: 600;
    }

    @media (max-width: 480px) {
      h1 {
        font-size: 1.3rem;
      }

      .meta {
        flex-direction: column;
        gap: 0.2rem;
      }

      .content :global(h2) {
        font-size: 1.1rem;
        margin-top: 1.5rem;
      }

      .content :global(h3) {
        font-size: 1rem;
      }

      .content :global(pre) {
        padding: 0.8rem;
        font-size: 0.8rem;
        border-radius: 4px;
      }

      .content :global(pre code) {
        font-size: 0.8rem;
      }

      .content :global(table) {
        font-size: 0.8rem;
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }

      .content :global(th),
      .content :global(td) {
        padding: 0.4rem 0.6rem;
      }
    }
  </style>

  <script>
    document.querySelectorAll(".content pre").forEach((pre) => {
      const code = pre.querySelector("code")

      if (pre.getAttribute("data-language") === "mermaid") {
        const mermaidDiv = document.createElement("div")
        mermaidDiv.className = "mermaid"
        mermaidDiv.textContent = code?.textContent ?? ""
        pre.parentNode?.replaceChild(mermaidDiv, pre)
        return
      }

      const wrapper = document.createElement("div")
      wrapper.className = "code-block"
      pre.parentNode?.insertBefore(wrapper, pre)
      wrapper.appendChild(pre)

      const btn = document.createElement("button")
      btn.className = "copy-btn"
      btn.textContent = "コピー"
      wrapper.appendChild(btn)

      btn.addEventListener("click", () => {
        const text = code?.textContent ?? pre.textContent ?? ""
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = "コピー済み"
          btn.classList.add("copied")
          setTimeout(() => {
            btn.textContent = "コピー"
            btn.classList.remove("copied")
          }, 2000)
        })
      })
    })

    if (document.querySelector(".mermaid")) {
      const script = document.createElement("script")
      const isDark = document.documentElement.dataset.theme === "dark"
      script.type = "module"
      script.textContent = `
        import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
        mermaid.initialize({ startOnLoad: true, theme: '${isDark ? "dark" : "neutral"}', fontFamily: 'system-ui, sans-serif' });
      `
      document.body.appendChild(script)
    }
  </script>
</Base>
