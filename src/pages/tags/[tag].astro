---
import { getCollection } from "astro:content"
import Base from "../../layouts/Base.astro"
import TagList from "../../components/TagList.astro"

export async function getStaticPaths() {
  const allProjects = await getCollection("projects")
  const projects = allProjects.filter((p) => p.data.status !== "draft")

  const tagSet = new Set<string>()
  projects.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)))

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      tag,
      projects: projects.filter((p) => p.data.tags.includes(tag)),
    },
  }))
}

const { tag, projects } = Astro.props
const sorted = [...projects].sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
const base = import.meta.env.BASE_URL
---

<Base title={`${tag} の記事一覧 | DX Lab`} description={`「${tag}」タグが付いた事例の一覧`}>
  <nav class="back">
    <a href={`${base}/`}>&larr; トップに戻る</a>
  </nav>

  <header>
    <h1>{tag}</h1>
    <p class="count">{sorted.length} 件の事例</p>
  </header>

  <ul class="projects">
    {sorted.map((project) => (
      <li>
        <a href={`${base}/projects/${project.id}/`}>
          <h3>{project.data.title}</h3>
          <p>{project.data.description}</p>
          <TagList tags={project.data.tags} />
        </a>
      </li>
    ))}
  </ul>

  <style>
    .back {
      margin-bottom: 2rem;
    }

    .back a {
      color: #777;
      text-decoration: none;
      font-size: 0.9rem;
    }

    .back a:hover {
      color: #444;
    }

    header {
      margin-bottom: 2rem;
    }

    h1 {
      font-size: 1.6rem;
      font-weight: 700;
    }

    .count {
      margin-top: 0.3rem;
      color: #888;
      font-size: 0.85rem;
    }

    .projects {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .projects li {
      border: 1px solid #e8e6e3;
      border-radius: 8px;
      transition: border-color 0.2s;
    }

    .projects li:hover {
      border-color: #ccc;
    }

    .projects a {
      display: block;
      padding: 1.2rem;
      text-decoration: none;
      color: inherit;
    }

    .projects h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0.4rem;
    }

    .projects p {
      font-size: 0.9rem;
      color: #666;
      margin-bottom: 0.8rem;
    }
  </style>
</Base>
