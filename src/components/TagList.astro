---
interface Props {
  tags: string[]
  linked?: boolean
}

const { tags, linked = false } = Astro.props
const base = import.meta.env.BASE_URL
---

<div class="tags">
  {tags.map((tag) =>
    linked ? (
      <a class="tag" href={`${base}/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
    ) : (
      <span class="tag">{tag}</span>
    )
  )}
</div>

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.15rem 0.6rem;
    background: #f0eeeb;
    border-radius: 4px;
    color: #777;
    text-decoration: none;
    transition: background 0.2s;
  }

  a.tag:hover {
    background: #e5e3e0;
    color: #444;
  }
</style>
