---
interface Props {
  articleSlug: string
}

const { articleSlug } = Astro.props
const apiUrl = import.meta.env.PUBLIC_LIKE_API_URL ?? ""
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? ""
---

<section
  class="like-panel"
  data-like-root
  data-article-slug={articleSlug}
  data-api-url={apiUrl}
  data-turnstile-site-key={turnstileSiteKey}
  aria-label="いいね"
>
  <div class="like-panel__header">
    <h2>Like</h2>
    <p>参考になった記事にだけ、1回だけ押せます。</p>
  </div>

  <div class="like-panel__body">
    <button class="like-button" type="button" disabled>
      <span class="like-button__label">いいね</span>
      <span class="like-button__count" data-like-count>0</span>
    </button>
    <p class="like-panel__status" data-like-status>読み込み中...</p>
  </div>

  <div class="like-panel__turnstile" data-turnstile-container></div>
</section>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" defer></script>

<script>
  (() => {
    const root = document.querySelector("[data-like-root]");

    if (!root) return;

    const button = root.querySelector(".like-button");
    const countNode = root.querySelector("[data-like-count]");
    const statusNode = root.querySelector("[data-like-status]");
    const turnstileContainer = root.querySelector("[data-turnstile-container]");

    if (!button || !countNode || !statusNode || !turnstileContainer) return;

    const articleSlug = root.getAttribute("data-article-slug") ?? "";
    const apiUrl = (root.getAttribute("data-api-url") ?? "").replace(/\/$/, "");
    const turnstileSiteKey = root.getAttribute("data-turnstile-site-key") ?? "";
    const visitorStorageKey = "dx-lab-like-visitor-id";

    let liked = false;
    let widgetId = null;
    let currentCount = 0;
    let pendingTokenHandler = null;
    let pendingTokenReject = null;

    const setStatus = (message) => {
      statusNode.textContent = message;
    };

    const setCount = (count) => {
      currentCount = count;
      countNode.textContent = String(count);
    };

    const syncButton = () => {
      button.disabled = liked || !apiUrl || !turnstileSiteKey;
      button.classList.toggle("is-liked", liked);
    };

    const getVisitorId = () => {
      try {
        const stored = window.localStorage.getItem(visitorStorageKey);

        if (stored) return stored;

        const created = window.crypto?.randomUUID?.() ?? `${Date.now()}-${Math.random()}`;
        window.localStorage.setItem(visitorStorageKey, created);
        return created;
      } catch {
        return window.crypto?.randomUUID?.() ?? `${Date.now()}-${Math.random()}`;
      }
    };

    const markLiked = () => {
      liked = true;

      syncButton();
    };

    const buildLikeUrl = () => {
      const params = new URLSearchParams({ visitorId: getVisitorId() });
      return `${apiUrl}/likes/${encodeURIComponent(articleSlug)}?${params.toString()}`;
    };

    const fetchState = async () => {
      if (!apiUrl || !turnstileSiteKey) {
        setStatus("いいね機能は準備中です。");
        syncButton();
        return;
      }

      try {
        const response = await fetch(buildLikeUrl(), {
          headers: { Accept: "application/json" },
        });

        if (!response.ok) throw new Error("Failed to fetch likes");

        const data = await response.json();
        setCount(data.count ?? 0);
        liked = Boolean(data.liked);

        syncButton();
        setStatus(liked ? "このブラウザでは押済みです。" : "参考になったら押してください。");
      } catch {
        setStatus("いいねの読み込みに失敗しました。");
        syncButton();
      }
    };

    const waitForTurnstile = () =>
      new Promise((resolve, reject) => {
        let attempts = 0;
        const timer = window.setInterval(() => {
          attempts += 1;

          if (window.turnstile) {
            window.clearInterval(timer);
            resolve(window.turnstile);
            return;
          }

          if (attempts >= 50) {
            window.clearInterval(timer);
            reject(new Error("Turnstile unavailable"));
          }
        }, 100);
      });

    const getWidgetId = async () => {
      if (widgetId !== null) return widgetId;

      const turnstile = await waitForTurnstile();

      widgetId = turnstile.render(turnstileContainer, {
        sitekey: turnstileSiteKey,
        size: "invisible",
        callback: (token) => {
          if (pendingTokenHandler) pendingTokenHandler(token);
        },
        "error-callback": () => {
          if (pendingTokenReject) pendingTokenReject(new Error("Turnstile verification failed"));
          pendingTokenHandler = null;
          pendingTokenReject = null;
          setStatus("認証に失敗しました。時間をおいて再度お試しください。");
          syncButton();
        },
        "expired-callback": () => {
          pendingTokenHandler = null;
          pendingTokenReject = null;
        },
      });

      return widgetId;
    };

    const executeTurnstile = async () => {
      const turnstile = await waitForTurnstile();
      const id = await getWidgetId();

      return new Promise((resolve, reject) => {
        pendingTokenHandler = (token) => {
          pendingTokenHandler = null;
          pendingTokenReject = null;
          resolve(token);
        };
        pendingTokenReject = reject;

        try {
          turnstile.reset(id);
          turnstile.execute(id);
        } catch (error) {
          pendingTokenHandler = null;
          pendingTokenReject = null;
          reject(error);
        }
      });
    };

    const submitLike = async () => {
      if (liked) return;

      button.disabled = true;
      setStatus("確認中...");

      try {
        const turnstileToken = await executeTurnstile();
        const response = await fetch(`${apiUrl}/likes/${encodeURIComponent(articleSlug)}`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify({
            articleSlug,
            visitorId: getVisitorId(),
            turnstileToken,
          }),
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error ?? "Failed to like article");
        }

        setCount(data.count ?? currentCount);
        markLiked();
        setStatus(data.status === "already-liked" ? "このブラウザでは押済みです。" : "いいねしました。");
      } catch {
        syncButton();
        setStatus("いいねに失敗しました。時間をおいて再度お試しください。");
      }
    };

    button.addEventListener("click", submitLike);
    fetchState();
  })();
</script>

<style>
  .like-panel {
    margin-top: 2.5rem;
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .like-panel__header {
    margin-bottom: 0.9rem;
  }

  .like-panel__header h2 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .like-panel__header p {
    color: var(--subtle);
    font-size: 0.82rem;
  }

  .like-panel__body {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .like-button {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 7rem;
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface-muted);
    color: var(--text);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .like-button:hover:not(:disabled) {
    background: var(--surface-hover);
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }

  .like-button:disabled {
    cursor: default;
    opacity: 0.72;
  }

  .like-button.is-liked {
    background: var(--accent);
    color: var(--accent-contrast);
    border-color: var(--accent);
    opacity: 1;
  }

  .like-button__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.75rem;
    padding: 0.08rem 0.4rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
  }

  .like-button:not(.is-liked) .like-button__count {
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .like-panel__status {
    color: var(--subtle);
    font-size: 0.82rem;
  }

  .like-panel__turnstile {
    min-height: 1px;
  }

  @media (max-width: 480px) {
    .like-panel {
      margin-top: 2rem;
      padding: 0.95rem 1rem;
    }

    .like-panel__body {
      align-items: flex-start;
      gap: 0.7rem;
    }
  }
</style>
