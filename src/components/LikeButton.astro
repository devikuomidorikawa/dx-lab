---
interface Props {
  articleSlug: string
  articleTitle?: string
  compact?: boolean
}

const { articleSlug, articleTitle = "", compact = false } = Astro.props
const apiUrl = import.meta.env.PUBLIC_LIKE_API_URL ?? ""
const base = import.meta.env.BASE_URL
const sharePath = `${base}projects/${articleSlug}/`
---

<section
  class:list={["like-panel", compact && "like-panel--compact"]}
  data-like-root
  data-article-slug={articleSlug}
  data-article-title={articleTitle}
  data-share-path={sharePath}
  data-api-url={apiUrl}
  aria-label="いいねと共有"
>
  <div class="like-panel__actions">
    <button class="icon-button like-button" type="button" disabled title="いいね" aria-label="いいね">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M12 21.35 10.55 20.03C5.1 15.1 2 12.24 2 8.75 2 5.89 4.24 3.7 7.11 3.7c1.62 0 3.18.76 4.18 1.95.99-1.19 2.55-1.95 4.17-1.95C18.34 3.7 20.58 5.89 20.58 8.75c0 3.49-3.1 6.35-8.58 11.28L12 21.35Z"
        />
      </svg>
      <span class="sr-only">いいね</span>
    </button>

    <span class="like-count" data-like-count aria-live="polite">0</span>

    <button class="icon-button share-button" type="button" title="共有" aria-label="リンクを共有">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M18 8a3 3 0 1 0-2.83-4H15a3 3 0 0 0 3 3zm-12 9a3 3 0 1 0 2.83 4H9a3 3 0 0 0-3-3zm12 0a3 3 0 1 0 2.83 4H15a3 3 0 0 0 3-3z" />
        <path d="M8.59 15.51 15.42 19.2M15.41 4.8 8.59 8.49" />
      </svg>
      <span class="sr-only">共有</span>
    </button>
  </div>

  <p class="sr-only" data-like-status>読み込み中...</p>
</section>

<script>
  (() => {
    const visitorStorageKey = "dx-lab-like-visitor-id";
    const likedStoragePrefix = "dx-lab-liked:";

    const roots = Array.from(document.querySelectorAll("[data-like-root]"));

    if (roots.length === 0) {
      return;
    }

    const apiUrl = roots[0].getAttribute("data-api-url") ?? "";

    const stateBySlug = new Map();

    const getVisitorId = () => {
      try {
        const stored = window.localStorage.getItem(visitorStorageKey);
        if (stored) return stored;

        const created = window.crypto?.randomUUID?.() ?? `${Date.now()}-${Math.random()}`;
        window.localStorage.setItem(visitorStorageKey, created);
        return created;
      } catch {
        return window.crypto?.randomUUID?.() ?? `${Date.now()}-${Math.random()}`;
      }
    };

    const getLikedStorageKey = (slug) => `${likedStoragePrefix}${slug}`;

    const isLikedLocally = (slug) => {
      try {
        return window.localStorage.getItem(getLikedStorageKey(slug)) === "1";
      } catch {
        return false;
      }
    };

    const setLikedLocally = (slug) => {
      try {
        window.localStorage.setItem(getLikedStorageKey(slug), "1");
      } catch {
        // ignore
      }
    };

    const getRootsForSlug = (slug) =>
      roots.filter((root) => root.getAttribute("data-article-slug") === slug);

    const setStatus = (slug, message) => {
      getRootsForSlug(slug).forEach((root) => {
        const statusNode = root.querySelector("[data-like-status]");
        if (statusNode) {
          statusNode.textContent = message;
        }
      });
    };

    const updateRoots = (slug, nextState) => {
      stateBySlug.set(slug, nextState);
      getRootsForSlug(slug).forEach((root) => {
        const likeButton = root.querySelector(".like-button");
        const countNode = root.querySelector("[data-like-count]");
        const shareButton = root.querySelector(".share-button");

        if (!likeButton || !countNode || !shareButton) return;

        countNode.textContent = String(nextState.count);
        likeButton.disabled = nextState.liked;
        likeButton.classList.toggle("is-liked", nextState.liked);
        likeButton.setAttribute("title", nextState.liked ? "いいね済み" : "いいね");
        likeButton.setAttribute("aria-label", nextState.liked ? "いいね済み" : "いいね");
      });
    };

    const fetchState = async (slug) => {
      const response = await fetch(
        `${apiUrl}/likes/${encodeURIComponent(slug)}?visitorId=${encodeURIComponent(getVisitorId())}`,
        {
          headers: { Accept: "application/json" },
        },
      );

      if (!response.ok) {
        throw new Error("Failed to fetch likes");
      }

      return response.json();
    };

    const submitLike = async (slug) => {
      const localLiked = isLikedLocally(slug);
      const current = stateBySlug.get(slug);

      if (localLiked || current?.liked) {
        updateRoots(slug, {
          count: current?.count ?? 0,
          liked: true,
        });
        return;
      }

      updateRoots(slug, {
        count: current?.count ?? 0,
        liked: false,
      });

      const response = await fetch(`${apiUrl}/likes/${encodeURIComponent(slug)}`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify({
          visitorId: getVisitorId(),
        }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error ?? "Failed to like article");
      }

      setLikedLocally(slug);
      updateRoots(slug, {
        count: data.count ?? current?.count ?? 0,
        liked: true,
      });
    };

    const copyText = async (value) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(value);
        return true;
      }

      const textarea = document.createElement("textarea");
      textarea.value = value;
      textarea.setAttribute("readonly", "true");
      textarea.style.position = "fixed";
      textarea.style.left = "-9999px";
      document.body.appendChild(textarea);
      textarea.select();

      let copied = false;
      try {
        copied = document.execCommand("copy");
      } finally {
        textarea.remove();
      }

      return copied;
    };

    const shareArticle = async (root) => {
      const slug = root.getAttribute("data-article-slug");
      const sharePath = root.getAttribute("data-share-path");
      const title = root.getAttribute("data-article-title") || document.title;

      if (!slug || !sharePath) return;

      const shareUrl = new URL(sharePath, window.location.origin).href;
      const shareText = title;

      try {
        if (navigator.share) {
          await navigator.share({
            title,
            text: shareText,
            url: shareUrl,
          });
        } else {
          await copyText(shareUrl);
        }
        setStatus(slug, "共有リンクを用意しました。");
      } catch (error) {
        if (error instanceof DOMException && error.name === "AbortError") {
          return;
        }

        try {
          await copyText(shareUrl);
          setStatus(slug, "共有リンクをコピーしました。");
        } catch {
          setStatus(slug, "共有に失敗しました。");
        }
      }
    };

    const wireRoot = (root) => {
      const slug = root.getAttribute("data-article-slug");
      const likeButton = root.querySelector(".like-button");
      const shareButton = root.querySelector(".share-button");
      const countNode = root.querySelector("[data-like-count]");
      const statusNode = root.querySelector("[data-like-status]");

      if (!slug || !likeButton || !shareButton || !countNode || !statusNode) return;

      likeButton.addEventListener("click", async () => {
        likeButton.disabled = true;
        setStatus(slug, "確認中...");

        try {
          await submitLike(slug);
          setStatus(slug, "いいねしました。");
        } catch {
          const current = stateBySlug.get(slug);
          likeButton.disabled = Boolean(current?.liked);
          setStatus(slug, "いいねに失敗しました。");
        }
      });

      shareButton.addEventListener("click", async () => {
        setStatus(slug, "共有中...");
        await shareArticle(root);
      });
    };

    roots.forEach(wireRoot);

    const uniqueSlugs = [...new Set(roots.map((root) => root.getAttribute("data-article-slug")).filter(Boolean))];

    uniqueSlugs.forEach(async (slug) => {
      try {
        const data = await fetchState(slug);
        const liked = Boolean(data.liked) || isLikedLocally(slug);
        updateRoots(slug, {
          count: data.count ?? 0,
          liked,
        });
        setStatus(slug, liked ? "このブラウザでは押済みです。" : "いいねできます。");
      } catch {
        updateRoots(slug, {
          count: 0,
          liked: isLikedLocally(slug),
        });
        setStatus(slug, "いいねの読み込みに失敗しました。");
      }
    });
  })();
</script>

<style>
  .like-panel {
    display: flex;
    align-items: center;
  }

  .like-panel__actions {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.32rem 0.45rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface-muted);
    color: var(--text);
    box-shadow: var(--shadow);
    flex-wrap: nowrap;
  }

  .like-panel--compact .like-panel__actions {
    padding: 0.25rem 0.35rem;
    gap: 0.35rem;
  }

  .icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: inherit;
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }

  .like-panel--compact .icon-button {
    width: 1.75rem;
    height: 1.75rem;
  }

  .icon-button:hover:not(:disabled) {
    background: var(--surface-hover);
    transform: translateY(-1px);
  }

  .icon-button:disabled {
    cursor: default;
    opacity: 0.55;
  }

  .icon-button svg {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
    stroke: currentColor;
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .like-button.is-liked {
    color: var(--accent);
  }

  .like-count {
    min-width: 1.5rem;
    padding: 0 0.2rem;
    text-align: center;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
  }

  .like-panel--compact .like-count {
    font-size: 0.82rem;
    min-width: 1.35rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
