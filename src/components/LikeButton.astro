---
interface Props {
  articleSlug: string
  compact?: boolean
}

const { articleSlug, compact = false } = Astro.props
const apiUrl = import.meta.env.PUBLIC_LIKE_API_URL ?? ""
---

<section
  class:list={["like-panel", compact && "like-panel--compact"]}
  data-like-root
  data-article-slug={articleSlug}
  data-api-url={apiUrl}
  aria-label="いいね"
>
  <button class="like-button" type="button" disabled>
    <span class="like-button__label">いいね</span>
    <span class="like-button__count" data-like-count>0</span>
  </button>
  <p class="like-panel__status" data-like-status>読み込み中...</p>
</section>

<script>
  (() => {
    const visitorStorageKey = "dx-lab-like-visitor-id";
    const likedStoragePrefix = "dx-lab-liked:";

    const roots = Array.from(document.querySelectorAll("[data-like-root]"));

    if (roots.length === 0) {
      return;
    }

    const apiUrl = roots[0].getAttribute("data-api-url") ?? "";

    if (!apiUrl) {
      roots.forEach((root) => {
        const statusNode = root.querySelector("[data-like-status]");
        if (statusNode) statusNode.textContent = "いいね機能は準備中です。";
      });
      return;
    }

    const stateBySlug = new Map();

    const getVisitorId = () => {
      try {
        const stored = window.localStorage.getItem(visitorStorageKey);
        if (stored) return stored;

        const created = window.crypto?.randomUUID?.() ?? `${Date.now()}-${Math.random()}`;
        window.localStorage.setItem(visitorStorageKey, created);
        return created;
      } catch {
        return window.crypto?.randomUUID?.() ?? `${Date.now()}-${Math.random()}`;
      }
    };

    const getLikedStorageKey = (slug) => `${likedStoragePrefix}${slug}`;

    const isLikedLocally = (slug) => {
      try {
        return window.localStorage.getItem(getLikedStorageKey(slug)) === "1";
      } catch {
        return false;
      }
    };

    const setLikedLocally = (slug) => {
      try {
        window.localStorage.setItem(getLikedStorageKey(slug), "1");
      } catch {
        // ignore
      }
    };

    const getRootsForSlug = (slug) =>
      roots.filter((root) => root.getAttribute("data-article-slug") === slug);

    const updateRoots = (slug, nextState) => {
      stateBySlug.set(slug, nextState);
      getRootsForSlug(slug).forEach((root) => {
        const button = root.querySelector(".like-button");
        const countNode = root.querySelector("[data-like-count]");
        const statusNode = root.querySelector("[data-like-status]");

        if (!button || !countNode || !statusNode) return;

        countNode.textContent = String(nextState.count);
        button.disabled = nextState.liked;
        button.classList.toggle("is-liked", nextState.liked);
        statusNode.textContent = nextState.liked
          ? "このブラウザでは押済みです。"
          : "参考になったら押してください。";
      });
    };

    const fetchState = async (slug) => {
      const response = await fetch(
        `${apiUrl}/likes/${encodeURIComponent(slug)}?visitorId=${encodeURIComponent(getVisitorId())}`,
        {
          headers: { Accept: "application/json" },
        },
      );

      if (!response.ok) {
        throw new Error("Failed to fetch likes");
      }

      return response.json();
    };

    const submitLike = async (slug) => {
      const localLiked = isLikedLocally(slug);
      const current = stateBySlug.get(slug);

      if (localLiked || current?.liked) {
        updateRoots(slug, {
          count: current?.count ?? 0,
          liked: true,
        });
        return;
      }

      updateRoots(slug, {
        count: current?.count ?? 0,
        liked: false,
      });

      const response = await fetch(`${apiUrl}/likes/${encodeURIComponent(slug)}`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify({
          visitorId: getVisitorId(),
        }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error ?? "Failed to like article");
      }

      setLikedLocally(slug);
      updateRoots(slug, {
        count: data.count ?? current?.count ?? 0,
        liked: true,
      });
    };

    const wireRoot = (root) => {
      const slug = root.getAttribute("data-article-slug");
      const button = root.querySelector(".like-button");
      const countNode = root.querySelector("[data-like-count]");
      const statusNode = root.querySelector("[data-like-status]");

      if (!slug || !button || !countNode || !statusNode) return;

      button.addEventListener("click", async () => {
        button.disabled = true;
        statusNode.textContent = "確認中...";

        try {
          await submitLike(slug);
        } catch {
          const current = stateBySlug.get(slug);
          button.disabled = Boolean(current?.liked);
          statusNode.textContent = "いいねに失敗しました。時間をおいて再度お試しください。";
        }
      });
    };

    roots.forEach(wireRoot);

    const uniqueSlugs = [...new Set(roots.map((root) => root.getAttribute("data-article-slug")).filter(Boolean))];

    uniqueSlugs.forEach(async (slug) => {
      try {
        const data = await fetchState(slug);
        const liked = Boolean(data.liked) || isLikedLocally(slug);
        updateRoots(slug, {
          count: data.count ?? 0,
          liked,
        });
      } catch {
        updateRoots(slug, {
          count: 0,
          liked: isLikedLocally(slug),
        });
        getRootsForSlug(slug).forEach((root) => {
          const statusNode = root.querySelector("[data-like-status]");
          if (statusNode) statusNode.textContent = "いいねの読み込みに失敗しました。";
        });
      }
    });
  })();
</script>

<style>
  .like-panel {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .like-panel--compact {
    gap: 0.6rem;
  }

  .like-button {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 7rem;
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface-muted);
    color: var(--text);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .like-panel--compact .like-button {
    min-width: 6.4rem;
    padding: 0.5rem 0.8rem;
    font-size: 0.82rem;
  }

  .like-button:hover:not(:disabled) {
    background: var(--surface-hover);
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }

  .like-button:disabled {
    cursor: default;
    opacity: 0.72;
  }

  .like-button.is-liked {
    background: var(--accent);
    color: var(--accent-contrast);
    border-color: var(--accent);
    opacity: 1;
  }

  .like-button__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.75rem;
    padding: 0.08rem 0.4rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
  }

  .like-button:not(.is-liked) .like-button__count {
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .like-panel__status {
    color: var(--subtle);
    font-size: 0.82rem;
  }

  .like-panel--compact .like-panel__status {
    font-size: 0.76rem;
  }

  @media (max-width: 480px) {
    .like-panel {
      gap: 0.55rem;
    }
  }
</style>
