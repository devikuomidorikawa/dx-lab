---
interface Props {
  articleSlug: string
  articleTitle?: string
  compact?: boolean
}

const { articleSlug, articleTitle = "", compact = false } = Astro.props
const apiUrl = import.meta.env.PUBLIC_LIKE_API_URL ?? ""
const base = import.meta.env.BASE_URL
const sharePath = `${base}projects/${articleSlug}/`
---

<section
  class:list={["reaction-bar", compact && "reaction-bar--compact"]}
  data-like-root
  data-article-slug={articleSlug}
  data-article-title={articleTitle}
  data-share-path={sharePath}
  data-api-url={apiUrl}
  aria-label="いいねと共有"
>
  <div class="reaction-bar__inner">
    <button class="icon-button like-button" type="button" title="いいね" aria-label="いいね">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M12 21.35 10.55 20.03C5.1 15.1 2 12.24 2 8.75 2 5.89 4.24 3.7 7.11 3.7c1.62 0 3.18.76 4.18 1.95.99-1.19 2.55-1.95 4.17-1.95C18.34 3.7 20.58 5.89 20.58 8.75c0 3.49-3.1 6.35-8.58 11.28L12 21.35Z"
        />
      </svg>
    </button>

    <span class="reaction-count" data-like-count aria-live="polite">0</span>

    <button class="icon-button share-button" type="button" title="共有" aria-label="リンクを共有">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M14 5a3 3 0 1 0 2.83 4H17a3 3 0 0 0-3-3z" />
        <path d="M10 9.5 14.1 7.4M10 14.5 14.1 16.6M7 13a3 3 0 1 0 2.83 4H10a3 3 0 0 0-3-3z" />
      </svg>
    </button>
  </div>

  <p class="sr-only" data-like-status>読み込み中...</p>
</section>

<script>
  (() => {
    const visitorStorageKey = "dx-lab-like-visitor-id";
    const likedStoragePrefix = "dx-lab-liked:";

    const roots = Array.from(document.querySelectorAll("[data-like-root]"));
    if (roots.length === 0) return;

    const apiUrl = roots[0].getAttribute("data-api-url") ?? "";
    const stateBySlug = new Map();

    const getVisitorId = () => {
      try {
        const stored = window.localStorage.getItem(visitorStorageKey);
        if (stored) return stored;
        const created = window.crypto?.randomUUID?.() ?? `${Date.now()}-${Math.random()}`;
        window.localStorage.setItem(visitorStorageKey, created);
        return created;
      } catch {
        return window.crypto?.randomUUID?.() ?? `${Date.now()}-${Math.random()}`;
      }
    };

    const localKey = (slug) => `${likedStoragePrefix}${slug}`;

    const getLocalLiked = (slug) => {
      try {
        return window.localStorage.getItem(localKey(slug)) === "1";
      } catch {
        return false;
      }
    };

    const setLocalLiked = (slug, liked) => {
      try {
        if (liked) {
          window.localStorage.setItem(localKey(slug), "1");
        } else {
          window.localStorage.removeItem(localKey(slug));
        }
      } catch {
        // ignore storage failures
      }
    };

    const getRootsForSlug = (slug) =>
      roots.filter((root) => root.getAttribute("data-article-slug") === slug);

    const setStatus = (slug, message) => {
      getRootsForSlug(slug).forEach((root) => {
        const statusNode = root.querySelector("[data-like-status]");
        if (statusNode) statusNode.textContent = message;
      });
    };

    const updateRoots = (slug, nextState) => {
      stateBySlug.set(slug, nextState);
      getRootsForSlug(slug).forEach((root) => {
        const likeButton = root.querySelector(".like-button");
        const shareButton = root.querySelector(".share-button");
        const countNode = root.querySelector("[data-like-count]");

        if (!likeButton || !shareButton || !countNode) return;

        countNode.textContent = String(nextState.count);
        likeButton.disabled = false;
        likeButton.classList.toggle("is-liked", nextState.liked);
        likeButton.setAttribute("title", nextState.liked ? "いいねを取り消す" : "いいね");
        likeButton.setAttribute("aria-label", nextState.liked ? "いいねを取り消す" : "いいね");
      });
    };

    const fetchState = async (slug) => {
      const response = await fetch(
        `${apiUrl}/likes/${encodeURIComponent(slug)}?visitorId=${encodeURIComponent(getVisitorId())}`,
        { headers: { Accept: "application/json" } },
      );

      if (!response.ok) throw new Error("Failed to fetch likes");
      return response.json();
    };

    const addLike = async (slug) => {
      const response = await fetch(`${apiUrl}/likes/${encodeURIComponent(slug)}`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify({ visitorId: getVisitorId() }),
      });

      const data = await response.json();
      if (!response.ok) throw new Error(data.error ?? "Failed to like article");

      setLocalLiked(slug, true);
      updateRoots(slug, {
        count: data.count ?? 0,
        liked: true,
      });
    };

    const removeLike = async (slug) => {
      const response = await fetch(
        `${apiUrl}/likes/${encodeURIComponent(slug)}?visitorId=${encodeURIComponent(getVisitorId())}`,
        {
          method: "DELETE",
          headers: { Accept: "application/json" },
        },
      );

      const data = await response.json();
      if (!response.ok) throw new Error(data.error ?? "Failed to remove like");

      setLocalLiked(slug, false);
      updateRoots(slug, {
        count: data.count ?? 0,
        liked: false,
      });
    };

    const copyText = async (value) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(value);
        return true;
      }

      const textarea = document.createElement("textarea");
      textarea.value = value;
      textarea.setAttribute("readonly", "true");
      textarea.style.position = "fixed";
      textarea.style.left = "-9999px";
      document.body.appendChild(textarea);
      textarea.select();

      let copied = false;
      try {
        copied = document.execCommand("copy");
      } finally {
        textarea.remove();
      }

      return copied;
    };

    const shareArticle = async (root) => {
      const slug = root.getAttribute("data-article-slug");
      const sharePath = root.getAttribute("data-share-path");
      const title = root.getAttribute("data-article-title") || document.title;

      if (!slug || !sharePath) return;

      const shareUrl = new URL(sharePath, window.location.origin).href;

      try {
        if (navigator.share) {
          await navigator.share({ title, text: title, url: shareUrl });
        } else {
          await copyText(shareUrl);
        }
        setStatus(slug, "共有リンクを用意しました。");
      } catch (error) {
        if (error instanceof DOMException && error.name === "AbortError") return;

        try {
          await copyText(shareUrl);
          setStatus(slug, "共有リンクをコピーしました。");
        } catch {
          setStatus(slug, "共有に失敗しました。");
        }
      }
    };

    const wireRoot = (root) => {
      const slug = root.getAttribute("data-article-slug");
      const likeButton = root.querySelector(".like-button");
      const shareButton = root.querySelector(".share-button");

      if (!slug || !likeButton || !shareButton) return;

      likeButton.addEventListener("click", async () => {
        const current = stateBySlug.get(slug);
        likeButton.disabled = true;
        setStatus(slug, current?.liked ? "いいねを取り消し中..." : "いいね中...");

        try {
          if (current?.liked) {
            await removeLike(slug);
            setStatus(slug, "いいねを取り消しました。");
          } else {
            await addLike(slug);
            setStatus(slug, "いいねしました。");
          }
        } catch {
          const latest = stateBySlug.get(slug);
          setStatus(slug, latest?.liked ? "いいね済みです。" : "いいねに失敗しました。");
        } finally {
          likeButton.disabled = false;
        }
      });

      shareButton.addEventListener("click", async () => {
        setStatus(slug, "共有中...");
        await shareArticle(root);
      });
    };

    roots.forEach(wireRoot);

    const uniqueSlugs = [...new Set(roots.map((root) => root.getAttribute("data-article-slug")).filter(Boolean))];
    uniqueSlugs.forEach(async (slug) => {
      try {
        const data = await fetchState(slug);
        const liked = Boolean(data.liked) || getLocalLiked(slug);
        updateRoots(slug, {
          count: data.count ?? 0,
          liked,
        });
        setStatus(slug, liked ? "このブラウザではいいね済みです。" : "いいねできます。");
      } catch {
        updateRoots(slug, {
          count: 0,
          liked: getLocalLiked(slug),
        });
        setStatus(slug, "いいねの読み込みに失敗しました。");
      }
    });
  })();
</script>

<style>
  .reaction-bar {
    display: inline-flex;
    align-items: center;
  }

  .reaction-bar__inner {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.1rem 0.2rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface-muted);
    color: var(--text);
    box-shadow: var(--shadow);
  }

  .reaction-bar--compact .reaction-bar__inner {
    gap: 0.15rem;
    padding: 0.05rem 0.15rem;
  }

  .icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.45rem;
    height: 1.45rem;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: inherit;
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }

  .reaction-bar--compact .icon-button {
    width: 1.25rem;
    height: 1.25rem;
  }

  .icon-button:hover:not(:disabled) {
    background: var(--surface-hover);
    transform: translateY(-1px);
  }

  .icon-button:disabled {
    cursor: default;
  }

  .icon-button svg {
    width: 0.8rem;
    height: 0.8rem;
    fill: currentColor;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .like-button.is-liked {
    color: var(--accent);
  }

  .reaction-count {
    min-width: 1.25rem;
    text-align: center;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1;
    color: var(--text);
  }

  .reaction-bar--compact .reaction-count {
    font-size: 0.7rem;
    min-width: 1.15rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
