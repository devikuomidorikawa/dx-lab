{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dx-lab-like-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-15",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dx-lab-likes",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],
  "vars": {
    "ALLOWED_ORIGINS": "https://devikuomidorikawa.github.io"
  }
}
